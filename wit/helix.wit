// TPT Helix — canonical WIT interface definitions.
//
// Source of truth: spec.txt §5.2. These interfaces are imported by guest
// WASM components (the host — the Helix Runtime — exports them). `wit-bindgen`
// generates, per interface:
//   * guest bindings: free functions the guest calls (e.g. `network::fetch`), and
//   * a `Host` trait that the Helix Runtime implements to provide the behavior.
//
// See crates/helix-wit (codegen) and crates/helix-runtime (stub Host impls + tests).

package helix:runtime@0.1.0;

interface network {
    // Shared error type surfaced by capability-checked operations.
    type error = string;

    record request {
        method: string,
        url: string,
        headers: list<tuple<string, string>>,
        body: option<list<u8>>,
    }

    record response {
        status: u16,
        headers: list<tuple<string, string>>,
        body: list<u8>,
    }

    // Performs an HTTP-flavored request. Fails with `error` when the module
    // lacks the network capability for `req.url` or the fetch cannot be made.
    fetch: func(req: request) -> result<response, error>;
}

interface storage {
    // Shared error type surfaced by capability-checked operations.
    type error = string;

    record key-value {
        key: string,
        value: list<u8>,
    }

    // Returns the value stored under `key`, or `none` if absent.
    get: func(key: string) -> option<list<u8>>;

    // Stores `value` under `key`. Fails if the module lacks write storage.
    set: func(key: string, value: list<u8>) -> result<_, error>;

    // Removes `key`. Fails if the module lacks write storage. Removing a
    // missing key is not an error.
    delete: func(key: string) -> result<_, error>;
}

interface dom {
    // Opaque handle to a node in the runtime's element tree.
    record element-id {
        id: u64,
    }

    // Creates a detached element of the given tag name.
    create-element: func(tag: string) -> element-id;

    // Replaces the text content of `el`.
    set-text: func(el: element-id, text: string);

    // Sets a single attribute on `el`.
    set-attribute: func(el: element-id, name: string, value: string);

    // Appends `child` as the last child of `parent`.
    append-child: func(parent: element-id, child: element-id);

    // Registers the click handler identified by `handler-id` to run when
    // `el` is clicked. `handler-id` is allocated and owned by the guest; the
    // runtime invokes it (via the capability broker / wasmtime) when the
    // event fires. Modeled as a guest-managed id rather than a WIT function
    // reference so the host stub can be exercised without a live guest.
    on-click: func(el: element-id, handler-id: u64);
}

// The Helix world: a guest imports the three capability interfaces above.
world helix {
    import network;
    import storage;
    import dom;
}

// The host-side counterpart: the Helix Runtime *provides* (exports) the same
// three interfaces to guests. Generating from this world makes `wit-bindgen`
// emit the `Guest` traits the runtime implements — our generated "Host"
// traits — without pulling in the wasmtime-dependent host generator.
world helix-host {
    export network;
    export storage;
    export dom;
}
