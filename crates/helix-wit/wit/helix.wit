// Helix Runtime WIT interfaces.
//
// These are the canonical capability interfaces a guest WASM module consumes
// from the Helix Runtime host. They are the source of truth for the generated
// host (`Guest` trait) and guest (call shim) bindings produced by
// `wit_bindgen`.
//
// Package `helix:runtime@0.1.0` generates Rust modules under
// `helix::runtime::{network, storage, dom}`.

package helix:runtime@0.1.0;

// ---------------------------------------------------------------------------
// network
// ---------------------------------------------------------------------------

interface network {
    record request {
        method: string,
        url: string,
        headers: list<tuple<string, string>>,
        body: option<list<u8>>,
    }

    record response {
        status: u16,
        headers: list<tuple<string, string>>,
        body: list<u8>,
    }

    // Issues a request and resolves to the response, or an error string
    // describing why the (capability-scoped) request was rejected / failed.
    fetch: func(req: request) -> result<response, string>;
}

// ---------------------------------------------------------------------------
// storage
// ---------------------------------------------------------------------------

interface storage {
    get: func(key: string) -> option<list<u8>>;
    set: func(key: string, value: list<u8>) -> result<_, string>;
    delete: func(key: string) -> result<_, string>;
}

// ---------------------------------------------------------------------------
// dom
// ---------------------------------------------------------------------------

interface dom {
    record element-id {
        id: u64,
    }

    create-element: func(tag: string) -> element-id;
    set-text: func(el: element-id, text: string);
    set-attribute: func(el: element-id, name: string, value: string);
    append-child: func(parent: element-id, child: element-id);

    // Registers a previously-declared click handler (identified by an opaque
    // `handler-id`) against an element. The runtime invokes the handler when
    // the element is activated. Callbacks cross the component boundary as
    // handles/ids rather than first-class function values.
    on-click: func(el: element-id, handler-id: u64);
}

// ---------------------------------------------------------------------------
// worlds
// ---------------------------------------------------------------------------

// The host (Helix Runtime) *exports* these capability interfaces: a guest
// component imports them and calls them. `wit_bindgen` generates a `Guest`
// trait per interface (under `host::exports`) that the native host implements.
world helix-runtime {
    export network;
    export storage;
    export dom;
}

// A guest module *imports* the same interfaces. `wit_bindgen` generates the
// call shims (`helix::runtime::network::fetch`, etc.) a guest compiles against.
// It also *exports* a `run` entry point that the host invokes after
// instantiation to drive the module (see the smoke-test guest in
// `crates/helix-guest-example` and the wasmtime host in `crates/helix-runtime`).
world helix-guest {
    import network;
    import storage;
    import dom;
    export run: func();
}
